"""
Commodity Price Forecasting API
Main Flask Application
"""

from flask import Flask, request, jsonify, send_file
from flask_cors import CORS
import os
from dotenv import load_dotenv
import traceback
import pandas as pd
from werkzeug.utils import secure_filename
from datetime import datetime
from sqlalchemy import text

from data.database_connector import DatabaseConnector
from models.prophet_forecasting import CommodityForecastModel

# Load environment variables
load_dotenv()

# Initialize Flask app
app = Flask(__name__)
CORS(app)
CORS(app, resources={
    r"/api/*": {
        "origins": [
            "http://localhost:3000",  # React
            "http://localhost:8000",  # Laravel
            "http://localhost:5173",  # Vite
            "http://127.0.0.1:3000",
            "http://127.0.0.1:8000",
            "http://127.0.0.1:5173"
        ],
        "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
        "allow_headers": ["Content-Type", "Authorization"]
    }
})

# Initialize database
db = DatabaseConnector()

# Configuration
PORT = int(os.getenv('FLASK_PORT', 5000))
DEBUG = os.getenv('FLASK_ENV', 'production') == 'development'

# Konfigurasi upload
UPLOAD_FOLDER = 'uploads'
ALLOWED_EXTENSIONS = {'csv'}

# Buat folder uploads jika belum ada
os.makedirs(UPLOAD_FOLDER, exist_ok=True)

def allowed_file(filename):
    """Check if file extension is allowed"""
    return '.' in filename and filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS


# ============================================================
# UPLOAD CSV ENDPOINTS
# ============================================================

@app.route('/api/upload/csv', methods=['POST'])
def upload_csv():
    """
    Upload CSV file containing price data
    
    CSV Format (sesuai template):
    id,tanggal,nama_komoditas,harga
    
    Contoh:
    1,2026-02-01,Beras Premium,12000
    2,2026-02-02,Gula Pasir,15000
    
    Request:
    - file: CSV file (multipart/form-data)
    
    Response:
    {
        "success": true,
        "message": "Data uploaded successfully",
        "data": {
            "total_records": 100,
            "inserted": 95,
            "updated": 3,
            "skipped": 2,
            "errors": []
        }
    }
    """
    try:
        # Check if file is in request
        if 'file' not in request.files:
            return jsonify({
                'success': False,
                'message': 'No file provided'
            }), 400
        
        file = request.files['file']
        
        # Check if file is selected
        if file.filename == '':
            return jsonify({
                'success': False,
                'message': 'No file selected'
            }), 400
        
        # Check file extension
        if not allowed_file(file.filename):
            return jsonify({
                'success': False,
                'message': 'Invalid file type. Only CSV files are allowed.'
            }), 400
        
        # Save file temporarily
        filename = secure_filename(file.filename)
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        filename = f"{timestamp}_{filename}"
        filepath = os.path.join(UPLOAD_FOLDER, filename)
        file.save(filepath)
        
        # Read CSV
        try:
            df = pd.read_csv(filepath, encoding='utf-8')
        except Exception as e:
            # Try with different encoding
            try:
                df = pd.read_csv(filepath, encoding='latin-1')
            except:
                os.remove(filepath)
                return jsonify({
                    'success': False,
                    'message': f'Error reading CSV file: {str(e)}'
                }), 400
        
        # Normalize column names (remove spaces, lowercase)
        df.columns = df.columns.str.strip().str.lower()
        
        # Validate CSV format
        required_columns = ['id', 'tanggal', 'nama_komoditas', 'harga']
        
        # Check if all required columns exist
        missing_columns = [col for col in required_columns if col not in df.columns]
        if missing_columns:
            os.remove(filepath)
            return jsonify({
                'success': False,
                'message': f'Missing required columns: {", ".join(missing_columns)}',
                'required_columns': required_columns,
                'found_columns': list(df.columns)
            }), 400
        
        # Process data
        inserted = 0
        updated = 0
        skipped = 0
        errors = []
        commodity_cache = {}  # Cache untuk mengurangi query database
        
        print(f"📊 Processing {len(df)} records from CSV...")
        
        for index, row in df.iterrows():
            try:
                # Get values from CSV
                csv_id = row['id']
                tanggal = row['tanggal']
                nama_komoditas = str(row['nama_komoditas']).strip()
                harga = row['harga']
                
                # Validate data
                if pd.isna(tanggal) or pd.isna(harga):
                    errors.append({
                        'row': index + 2,
                        'error': 'Missing tanggal or harga'
                    })
                    skipped += 1
                    continue
                
                # Parse date
                try:
                    date = pd.to_datetime(tanggal).strftime('%Y-%m-%d')
                except:
                    errors.append({
                        'row': index + 2,
                        'error': f'Invalid date format: {tanggal}'
                    })
                    skipped += 1
                    continue
                
                # Parse price
                try:
                    price = float(str(harga).replace(',', '').replace('Rp', '').strip())
                except:
                    errors.append({
                        'row': index + 2,
                        'error': f'Invalid price format: {harga}'
                    })
                    skipped += 1
                    continue
                
                # Find commodity_id by name
                # Check cache first
                if nama_komoditas in commodity_cache:
                    commodity_id = commodity_cache[nama_komoditas]
                else:
                    # Query database
                    # Split nama_komoditas menjadi nama dan varian jika ada
                    parts = nama_komoditas.split(' ', 1)
                    nama = parts[0]
                    varian = parts[1] if len(parts) > 1 else ''
                    
                    query = """
                        SELECT id FROM master_komoditas 
                        WHERE nama_komoditas LIKE :nama
                    """
                    
                    if varian:
                        query += " AND (nama_varian LIKE :varian OR nama_varian IS NULL OR nama_varian = '')"
                        params = {'nama': f'%{nama}%', 'varian': f'%{varian}%'}
                    else:
                        params = {'nama': f'%{nama}%'}
                    
                    with db.engine.connect() as conn:
                        result = conn.execute(text(query), params).fetchone()
                        
                        if not result:
                            errors.append({
                                'row': index + 2,
                                'error': f'Commodity not found: {nama_komoditas}'
                            })
                            skipped += 1
                            continue
                        
                        commodity_id = result[0]
                        commodity_cache[nama_komoditas] = commodity_id
                
                # Insert or update price data
                query = """
                    INSERT INTO price_data (komoditas_id, tanggal, harga, created_at, updated_at)
                    VALUES (:commodity_id, :date, :price, NOW(), NOW())
                    ON DUPLICATE KEY UPDATE
                    harga = VALUES(harga),
                    updated_at = NOW()
                """
                
                with db.engine.begin() as conn:
                    result = conn.execute(
                        text(query),
                        {
                            'commodity_id': commodity_id,
                            'date': date,
                            'price': price
                        }
                    )
                    
                    # Check if inserted or updated (rowcount = 1 untuk insert, 2 untuk update)
                    if result.rowcount == 1:
                        inserted += 1
                    elif result.rowcount == 2:
                        updated += 1
                
                # Progress indicator
                if (index + 1) % 10 == 0:
                    print(f"  Processed {index + 1}/{len(df)} records...")
                        
            except Exception as e:
                errors.append({
                    'row': index + 2,
                    'error': str(e)
                })
                skipped += 1
        
        # Clean up uploaded file
        os.remove(filepath)
        
        print(f"✅ Upload completed: {inserted} inserted, {updated} updated, {skipped} skipped")
        
        return jsonify({
            'success': True,
            'message': 'CSV uploaded and processed successfully',
            'data': {
                'total_records': len(df),
                'inserted': inserted,
                'updated': updated,
                'skipped': skipped,
                'errors': errors[:20]  # Limit errors to first 20
            }
        }), 200
        
    except Exception as e:
        print("Error in upload_csv:")
        print(traceback.format_exc())
        return jsonify({
            'success': False,
            'message': 'Error processing CSV upload',
            'error': str(e)
        }), 500


@app.route('/api/upload/template', methods=['GET'])
def download_template():
    """
    Download CSV template
    Format: id,tanggal,nama_komoditas,harga
    
    Response: CSV file
    """
    try:
        # Create template DataFrame
        template = pd.DataFrame({
            'id': [1, 2, 3, 4, 5],
            'tanggal': [
                '2026-02-01', 
                '2026-02-02', 
                '2026-02-03',
                '2026-02-04',
                '2026-02-05'
            ],
            'nama_komoditas': [
                'Beras Premium',
                'Beras Premium',
                'Gula Pasir',
                'Minyak Goreng',
                'Cabai Merah'
            ],
            'harga': [
                12000.00, 
                12100.00, 
                15000.00,
                18000.00,
                35000.00
            ]
        })
        
        # Save to CSV
        template_path = os.path.join(UPLOAD_FOLDER, 'template_price_data.csv')
        template.to_csv(template_path, index=False)
        
        return send_file(
            template_path,
            mimetype='text/csv',
            as_attachment=True,
            download_name='template_price_data.csv'
        )
        
    except Exception as e:
        return jsonify({
            'success': False,
            'message': 'Error generating template',
            'error': str(e)
        }), 500


@app.route('/api/commodities/search', methods=['GET'])
def search_commodities():
    """
    Search commodities by name
    
    Query Parameters:
    - q: search query
    
    Response:
    {
        "success": true,
        "data": [
            {
                "id": 1,
                "nama_komoditas": "Beras",
                "nama_varian": "Premium",
                "full_name": "Beras Premium"
            }
        ]
    }
    """
    try:
        search_query = request.args.get('q', '')
        
        if not search_query:
            return jsonify({
                'success': False,
                'message': 'Search query is required'
            }), 400
        
        query = """
            SELECT 
                id,
                nama_komoditas,
                nama_varian,
                CONCAT(nama_komoditas, ' ', IFNULL(nama_varian, '')) as full_name
            FROM master_komoditas
            WHERE nama_komoditas LIKE :search
               OR nama_varian LIKE :search
               OR CONCAT(nama_komoditas, ' ', IFNULL(nama_varian, '')) LIKE :search
            ORDER BY nama_komoditas, nama_varian
            LIMIT 20
        """
        
        with db.engine.connect() as conn:
            results = conn.execute(
                text(query),
                {'search': f'%{search_query}%'}
            ).fetchall()
            
            commodities = []
            for row in results:
                commodities.append({
                    'id': row[0],
                    'nama_komoditas': row[1],
                    'nama_varian': row[2] if row[2] else '',
                    'full_name': row[3].strip()
                })
        
        return jsonify({
            'success': True,
            'data': commodities
        }), 200
        
    except Exception as e:
        return jsonify({
            'success': False,
            'message': 'Error searching commodities',
            'error': str(e)
        }), 500


