@app.route('/api/forecast/predict', methods=['POST'])
def predict_forecast():
    """
    Generate forecast prediction
    
    Request Body:
    {
        "commodity_id": 1,
        "periods": 30,
        "frequency": "D"
    }
    
    Response:
    {
        "success": true,
        "data": {
            "commodity_id": 1,
            "predictions": [...],
            "model_metrics": {...}
        }
    }
    """
    try:
        # Get request data
        data = request.get_json()
        
        # Validate required fields
        if not data or 'commodity_id' not in data:
            return jsonify({
                'success': False,
                'message': 'commodity_id is required'
            }), 400
        
        commodity_id = data.get('commodity_id')
        periods = data.get('periods', 30)
        frequency = data.get('frequency', 'D')
        
        # Validate periods
        if periods < 1 or periods > 365:
            return jsonify({
                'success': False,
                'message': 'periods must be between 1 and 365'
            }), 400
        
        # Validate frequency
        if frequency not in ['D', 'W', 'M']:
            return jsonify({
                'success': False,
                'message': 'frequency must be D (daily), W (weekly), or M (monthly)'
            }), 400
        
        # Get commodity info
        commodity_info = db.get_commodity_info(commodity_id)
        if not commodity_info:
            return jsonify({
                'success': False,
                'message': f'Commodity with id {commodity_id} not found'
            }), 404
        
        # Get historical data from database
        historical_data = db.get_commodity_prices(commodity_id)
        
        if historical_data.empty:
            return jsonify({
                'success': False,
                'message': f'No historical data found for commodity_id {commodity_id}',
                'hint': 'Please add price data to the database first'
            }), 404
        
        # Check minimum data requirement
        if len(historical_data) < 30:
            return jsonify({
                'success': False,
                'message': 'Insufficient historical data. Minimum 30 data points required.',
                'current_data_points': len(historical_data)
            }), 400
        
        # Initialize forecasting model
        forecaster = CommodityForecastModel()
        
        # Train model
        forecaster.train(historical_data)
        
        # Generate forecast
        forecast_result = forecaster.predict(periods=periods, freq=frequency)
        
        # Get evaluation metrics
        metrics = forecaster.get_model_metrics()
        
        # Format response
        predictions = []
        for _, row in forecast_result.iterrows():
            predictions.append({
                'date': row['ds'].strftime('%Y-%m-%d'),
                'predicted_price': round(float(row['yhat']), 2),
                'lower_bound': round(float(row['yhat_lower']), 2),
                'upper_bound': round(float(row['yhat_upper']), 2),
                'trend': round(float(row['trend']), 2) if 'trend' in row else None
            })
        
        # Optional: Save forecast to database
        try:
            db.save_forecast_results(commodity_id, forecast_result)
        except:
            pass  # Silently fail if table doesn't exist
        
        return jsonify({
            'success': True,
            'data': {
                'commodity_id': commodity_id,
                'commodity_name': commodity_info['nama_komoditas'],
                'commodity_variant': commodity_info['nama_varian'],
                'unit': commodity_info['satuan'],
                'historical_data_points': len(historical_data),
                'forecast_period': periods,
                'frequency': frequency,
                'predictions': predictions,
                'model_metrics': metrics
            }
        }), 200
        
    except Exception as e:
        print("Error in predict_forecast:")
        print(traceback.format_exc())
        return jsonify({
            'success': False,
            'message': 'Internal server error',
            'error': str(e)
        }), 500

@app.route('/api/forecast/predict-advanced', methods=['POST'])
def predict_forecast_advanced():
    """
    Generate forecast dengan CUSTOM HYPERPARAMETERS dari frontend
    
    Request Body:
    {
        "commodity_id": 1,
        "periods": 30,
        "frequency": "D",
        "changepoint_prior_scale": 0.05,        # ← Custom hyperparameter
        "seasonality_prior_scale": 10,          # ← Custom hyperparameter
        "seasonality_mode": "multiplicative",   # ← Custom hyperparameter
        "weekly_seasonality": false,            # ← Custom hyperparameter
        "yearly_seasonality": true              # ← Custom hyperparameter
    }
    
    Response:
    {
        "success": true,
        "data": {
            "commodity_id": 1,
            "predictions": [...],
            "model_metrics": {...},
            "hyperparameters": {...}
        }
    }
    """
    try:
        # Get request data
        data = request.get_json()
        
        # ══ VALIDATE REQUIRED FIELDS ══════════════════════════════
        if not data or 'commodity_id' not in data:
            return jsonify({
                'success': False,
                'message': 'commodity_id is required'
            }), 400
        
        commodity_id = data.get('commodity_id')
        periods = data.get('periods', 30)
        frequency = data.get('frequency', 'D')
        
        # ══ GET HYPERPARAMETERS (dengan default values) ═══════════
        changepoint_prior_scale = float(data.get('changepoint_prior_scale', 0.05))
        seasonality_prior_scale = float(data.get('seasonality_prior_scale', 10))
        seasonality_mode = data.get('seasonality_mode', 'multiplicative')
        weekly_seasonality = bool(data.get('weekly_seasonality', False))
        yearly_seasonality = bool(data.get('yearly_seasonality', True))
        
        # ══ VALIDATE HYPERPARAMETERS ══════════════════════════════
        if changepoint_prior_scale < 0.001 or changepoint_prior_scale > 0.5:
            return jsonify({
                'success': False,
                'message': 'changepoint_prior_scale must be between 0.001 and 0.5'
            }), 400
        
        if seasonality_prior_scale < 0.01 or seasonality_prior_scale > 50:
            return jsonify({
                'success': False,
                'message': 'seasonality_prior_scale must be between 0.01 and 50'
            }), 400
        
        if seasonality_mode not in ['additive', 'multiplicative']:
            return jsonify({
                'success': False,
                'message': 'seasonality_mode must be "additive" or "multiplicative"'
            }), 400
        
        # ══ VALIDATE PERIODS & FREQUENCY ══════════════════════════
        if periods < 1 or periods > 365:
            return jsonify({
                'success': False,
                'message': 'periods must be between 1 and 365'
            }), 400
        
        if frequency not in ['D', 'W', 'M']:
            return jsonify({
                'success': False,
                'message': 'frequency must be D (daily), W (weekly), or M (monthly)'
            }), 400
        
        # ══ GET COMMODITY INFO ════════════════════════════════════
        commodity_info = db.get_commodity_info(commodity_id)
        if not commodity_info:
            return jsonify({
                'success': False,
                'message': f'Commodity with id {commodity_id} not found'
            }), 404
        
        # ══ GET HISTORICAL DATA ═══════════════════════════════════
        historical_data = db.get_commodity_prices(commodity_id)
        
        if historical_data.empty:
            return jsonify({
                'success': False,
                'message': f'No historical data found for commodity_id {commodity_id}',
                'hint': 'Please add price data to the database first'
            }), 404
        
        # ══ CHECK MINIMUM DATA ════════════════════════════════════
        if len(historical_data) < 30:
            return jsonify({
                'success': False,
                'message': 'Insufficient historical data. Minimum 30 data points required.',
                'current_data_points': len(historical_data)
            }), 400
        
        print(f"📊 Training model for commodity_id {commodity_id} with custom hyperparameters:")
        print(f"   - changepoint_prior_scale: {changepoint_prior_scale}")
        print(f"   - seasonality_prior_scale: {seasonality_prior_scale}")
        print(f"   - seasonality_mode: {seasonality_mode}")
        print(f"   - weekly_seasonality: {weekly_seasonality}")
        print(f"   - yearly_seasonality: {yearly_seasonality}")
        
        # ══ INITIALIZE MODEL WITH CUSTOM HYPERPARAMETERS ══════════
        forecaster = CommodityForecastModel(
            changepoint_prior_scale=changepoint_prior_scale,
            seasonality_prior_scale=seasonality_prior_scale,
            seasonality_mode=seasonality_mode,
            weekly_seasonality=weekly_seasonality,
            yearly_seasonality=yearly_seasonality
        )
        
        # ══ TRAIN MODEL ═══════════════════════════════════════════
        forecaster.train(historical_data)
        
        # ══ GENERATE FORECAST ═════════════════════════════════════
        forecast_result = forecaster.predict(periods=periods, freq=frequency)
        
        # ══ GET EVALUATION METRICS ════════════════════════════════
        metrics = forecaster.get_model_metrics()
        
        # ══ FORMAT PREDICTIONS ════════════════════════════════════
        predictions = []
        for _, row in forecast_result.iterrows():
            predictions.append({
                'date': row['ds'].strftime('%Y-%m-%d'),
                'predicted_price': round(float(row['yhat']), 2),
                'lower_bound': round(float(row['yhat_lower']), 2),
                'upper_bound': round(float(row['yhat_upper']), 2),
                'trend': round(float(row['trend']), 2) if 'trend' in row else round(float(row['yhat']), 2)
            })
        
        # ══ CALCULATE TREND DIRECTION ═════════════════════════════
        trend_values = forecast_result['yhat'].values
        if len(trend_values) > 1:
            trend_direction = 'increasing' if trend_values[-1] > trend_values[0] else 'decreasing'
        else:
            trend_direction = 'stable'
        
        # ══ SAVE FORECAST TO DATABASE ═════════════════════════════
        try:
            db.save_forecast_results(commodity_id, forecast_result)
            print(f"✅ Forecast saved to database for commodity_id {commodity_id}")
        except Exception as e:
            print(f"⚠️  Could not save forecast to database: {str(e)}")
            # Continue anyway - saving is optional
        
        # ══ BUILD RESPONSE ════════════════════════════════════════
        return jsonify({
            'success': True,
            'data': {
                'commodity_id': commodity_id,
                'commodity_name': commodity_info['nama_komoditas'],
                'commodity_variant': commodity_info['nama_varian'],
                'unit': commodity_info['satuan'],
                'historical_data_points': len(historical_data),
                'forecast_period': periods,
                'frequency': frequency,
                
                # Hyperparameters yang digunakan
                'hyperparameters': {
                    'changepoint_prior_scale': changepoint_prior_scale,
                    'seasonality_prior_scale': seasonality_prior_scale,
                    'seasonality_mode': seasonality_mode,
                    'weekly_seasonality': weekly_seasonality,
                    'yearly_seasonality': yearly_seasonality
                },
                
                # Predictions
                'predictions': predictions,
                
                # Model Metrics (enhanced)
                'model_metrics': {
                    'mape': float(metrics.get('mape', 0)),
                    'rmse': float(metrics.get('rmse', 0)),
                    'mae': float(metrics.get('mae', 0)),
                    'coverage': float(metrics.get('coverage', 0.95)),
                    'trend_direction': trend_direction,
                    'confidence_level': 0.95,
                    'average_prediction_interval': float(
                        forecast_result['yhat_upper'].mean() - 
                        forecast_result['yhat_lower'].mean()
                    )
                }
            }
        }), 200
        
    except Exception as e:
        print("Error in predict_forecast_advanced:")
        print(traceback.format_exc())
        return jsonify({
            'success': False,
            'message': 'Internal server error during advanced forecast',
            'error': str(e)
        }), 500


@app.route('/api/forecast/evaluate', methods=['POST'])
def evaluate_model():
    """
    Evaluate forecasting model performance
    
    Request Body:
    {
        "commodity_id": 1
    }
    
    Response:
    {
        "success": true,
        "data": {
            "evaluation_metrics": {...}
        }
    }
    """
    try:
        data = request.get_json()
        
        if not data or 'commodity_id' not in data:
            return jsonify({
                'success': False,
                'message': 'commodity_id is required'
            }), 400
        
        commodity_id = data.get('commodity_id')
        
        # Get historical data
        historical_data = db.get_commodity_prices(commodity_id)
        
        if historical_data.empty:
            return jsonify({
                'success': False,
                'message': f'No historical data found for commodity_id {commodity_id}'
            }), 404
        
        # Initialize and train model
        forecaster = CommodityForecastModel()
        forecaster.train(historical_data)
        
        # Get evaluation metrics
        metrics = forecaster.evaluate()
        
        return jsonify({
            'success': True,
            'data': {
                'commodity_id': commodity_id,
                'evaluation_metrics': metrics
            }
        }), 200
        
    except Exception as e:
        print(traceback.format_exc())
        return jsonify({
            'success': False,
            'message': 'Evaluation failed',
            'error': str(e)
        }), 500


@app.route('/api/commodities', methods=['GET'])
def get_commodities():
    """Get all commodities"""
    try:
        commodities = db.get_all_commodities()
        
        return jsonify({
            'success': True,
            'data': commodities
        }), 200
        
    except Exception as e:
        return jsonify({
            'success': False,
            'message': 'Error fetching commodities',
            'error': str(e)
        }), 500


@app.route('/api/commodities/<int:commodity_id>/statistics', methods=['GET'])
def get_commodity_statistics(commodity_id):
    """Get statistics for a specific commodity"""
    try:
        stats = db.get_price_statistics(commodity_id)
        
        if not stats:
            return jsonify({
                'success': False,
                'message': f'No data found for commodity_id {commodity_id}'
            }), 404
        
        return jsonify({
            'success': True,
            'data': stats
        }), 200
        
    except Exception as e:
        return jsonify({
            'success': False,
            'message': 'Error fetching statistics',
            'error': str(e)
        }), 500


# ============================================================
# ERROR HANDLERS
# ============================================================

@app.errorhandler(404)
def not_found(e):
    """Handle 404 errors"""
    return jsonify({
        'success': False,
        'message': 'Endpoint not found',
        'error': 'The requested endpoint does not exist'
    }), 404


@app.errorhandler(500)
def internal_error(e):
    """Handle 500 errors"""
    return jsonify({
        'success': False,
        'message': 'Internal server error'
    }), 500


